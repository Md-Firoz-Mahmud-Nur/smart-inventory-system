generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // url      = env("PRISMA_DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories   Category[]
  products     Product[]
  orders       Order[]
  activityLogs ActivityLog[]

  @@map("users")
}

model Category {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@index([userId])
  @@map("categories")
}

model Product {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId         String
  category           Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name               String
  price              Float
  stock              Int
  minimumStockThreshold Int    @default(5)
  status             String   @default("Active") // Active, Out of Stock
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  orderItems    OrderItem[]
  restockQueue  RestockQueue?

  @@index([userId])
  @@index([categoryId])
  @@index([status])
  @@map("products")
}

model Order {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  customerName  String
  totalPrice    Float    @default(0)
  status        String   @default("Pending") // Pending, Confirmed, Shipped, Delivered, Cancelled
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orderItems OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int
  price     Float
  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model RestockQueue {
  id        String   @id @default(cuid())
  productId String   @unique
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  priority  String   @default("Medium") // High, Medium, Low
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([priority])
  @@map("restock_queue")
}

model ActivityLog {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action   String // "Order Created", "Stock Updated", etc.
  orderId  String?
  productId String?
  details  String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}
